APP_NAME="Pokemon Stats Tracker"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://laravel-api-tracker-dashboard.onrender.com

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

POKEMON_API_URL=https://pokeapi.co/api/v2/pokemon/
POKEMON_MAX_ID=1025
POKEMON_API_TIMEOUT=60
POKEMON_API_RETRIES=3
POKEMON_API_RETRY_DELAY=100

GEO_API_URL=http://ip-api.com/json/
GEO_API_TIMEOUT=5
GEO_API_RETRIES=1

BROADCAST_DRIVER=null
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

